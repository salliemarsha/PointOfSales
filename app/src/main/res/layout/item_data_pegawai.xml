<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_employee"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="5dp"
    android:backgroundTint="@color/color3"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/color5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Icon Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/color5"
            app:cardBackgroundColor="@color/color1">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/pegawai"
                android:scaleType="centerInside"
                android:padding="14dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Employee Details -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/chipStatus"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tvNamaPegawai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pegawai"
                    android:textSize="15sp"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="@color/color2"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/role"
                        app:tint="@color/color6"/>

                    <TextView
                        android:id="@+id/tvRolePegawai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/jabatan"
                        android:textSize="11sp"
                        android:textColor="@color/color6"
                        android:fontFamily="@font/lato_regular"/>
                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="@string/aktif"
                android:textSize="10sp"
                android:textColor="@color/color2"
                app:chipBackgroundColor="@color/color1"
                app:chipStrokeColor="@color/color5"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="8dp"
                app:chipMinHeight="24dp"
                app:chipIcon="@drawable/ic_check"
                app:chipIconTint="@color/color4"
                app:chipIconSize="10dp"
                app:chipStartPadding="6dp"
                app:chipEndPadding="6dp"
                android:clickable="false"
                android:focusable="false"/>

        </RelativeLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>