<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_employee"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:backgroundTint="@color/tambahan"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="75dp"
            android:layout_height="75dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/pegawai"
                android:scaleType="centerInside"
                android:padding="8dp"/>
        </com.google.android.material.card.MaterialCardView>

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/chipStatus"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/tvNamaPegawai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pegawai"
                    android:textSize="16sp"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="@color/color2"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/role"
                        app:tint="@color/color6"/>

                    <TextView
                        android:id="@+id/tvRolePegawai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/jabatan"
                        android:textSize="12sp"
                        android:textColor="@color/color6"
                        android:fontFamily="@font/lato_regular"/>
                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="@string/aktif"
                android:textColor="@color/color2"
                android:textSize="11sp"
                android:fontFamily="@font/lato_bold"
                app:chipBackgroundColor="@color/card"
                app:chipCornerRadius="12dp"
                app:chipIcon="@drawable/ic_check"
                app:chipIconTint="@color/color2"
                app:chipIconSize="12dp"
                app:chipMinHeight="28dp"
                app:chipStartPadding="8dp"
                app:chipEndPadding="8dp"/>

        </RelativeLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>