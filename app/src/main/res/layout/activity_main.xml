<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color1"
    android:scrollbars="none"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/llPOS"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Top Header Panel -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tvDate"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/tvGreetings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/selamat_pagi"
                    android:textSize="20sp"
                    android:textColor="@color/color2"
                    android:fontFamily="@font/raleway_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kasir Aktif"
                    android:textSize="12sp"
                    android:textColor="@color/color4"
                    android:fontFamily="@font/lato_bold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="@string/tgl_bln_thn"
                android:textSize="13sp"
                android:textColor="@color/color6"
                android:fontFamily="@font/raleway_medium"
                android:background="@color/color3"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:elevation="1dp"/>
        </RelativeLayout>

        <!-- Earnings & Quick Actions Summary Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvPlace1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="8dp"
            android:backgroundTint="@color/color3"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/color5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvEstimasi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_medium"
                    android:text="@string/estimasi"
                    android:textColor="@color/color6"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvRP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_bold"
                    android:text="@string/rp0"
                    android:textColor="@color/color2"
                    android:textSize="28sp"
                    android:layout_marginTop="4dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/color5" />

                <!-- Quick Action Buttons: Transaction and Reports -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Transaksi Baru (Left Action) -->
                    <LinearLayout
                        android:id="@+id/llTransaksi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="12dp"
                        android:layout_marginEnd="8dp"
                        android:background="@color/akun"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:clipToPadding="false">

                        <ImageView
                            android:id="@+id/ivTransaksi"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/transaksi"
                            android:contentDescription="@string/transaksi" />

                        <TextView
                            android:id="@+id/tvTransaction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lato_bold"
                            android:text="@string/transaksi"
                            android:textColor="@color/color2"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- Laporan (Right Action) -->
                    <LinearLayout
                        android:id="@+id/llLaporan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="12dp"
                        android:layout_marginStart="8dp"
                        android:background="@color/cetak"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:clipToPadding="false">

                        <ImageView
                            android:id="@+id/ivLaporan"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/laporan"
                            android:contentDescription="@string/laporan" />

                        <TextView
                            android:id="@+id/tvReport"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lato_bold"
                            android:text="@string/laporan"
                            android:textColor="@color/color2"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Cashier Motivation / Commitment Quote -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:padding="16dp"
            android:background="@color/color3"
            android:elevation="0dp">

            <TextView
                android:id="@+id/tvGreetings2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/komitmen1"
                android:textSize="13sp"
                android:textColor="@color/color2"
                android:fontFamily="@font/raleway_bold" />

            <TextView
                android:id="@+id/tvGreetings3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/komitmen2"
                android:textSize="12sp"
                android:textColor="@color/color6"
                android:fontFamily="@font/raleway_medium"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Dashboard Grid Row 1 (Account, Product, Category) -->
        <LinearLayout
            android:id="@+id/llPOS2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="12dp"
            android:gravity="center">

            <!-- Card: Account -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvAccount"
                android:layout_width="0dp"
                android:layout_height="115dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:backgroundTint="@color/akun"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/ivAccount"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/akun"
                        android:contentDescription="@string/akun" />

                    <TextView
                        android:id="@+id/tvAccount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/akun"
                        android:textSize="13sp"
                        android:textColor="@color/color2"
                        android:fontFamily="@font/lato_bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Product -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvProduct"
                android:layout_width="0dp"
                android:layout_height="115dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:backgroundTint="@color/layanan"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/ivProduct"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/produk"
                        android:contentDescription="@string/produk" />

                    <TextView
                        android:id="@+id/tvProduct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/produk"
                        android:textSize="13sp"
                        android:textColor="@color/color2"
                        android:fontFamily="@font/lato_bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Category -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvCategory"
                android:layout_width="0dp"
                android:layout_height="115dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:backgroundTint="@color/tambahan"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/ivCategories"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/kategori"
                        android:contentDescription="@string/kategori" />

                    <TextView
                        android:id="@+id/tvCategories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/kategori"
                        android:textSize="13sp"
                        android:textColor="@color/color2"
                        android:fontFamily="@font/lato_bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Dashboard Grid Row 2 (Employee, Branch, Print) -->
        <LinearLayout
            android:id="@+id/llPOS3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="14dp"
            android:gravity="center">

            <!-- Card: Employee -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvEmployee"
                android:layout_width="0dp"
                android:layout_height="115dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:backgroundTint="@color/pegawai"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/ivEmployee"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/pegawai"
                        android:contentDescription="@string/pegawai" />

                    <TextView
                        android:id="@+id/tvEmployee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pegawai"
                        android:textSize="13sp"
                        android:textColor="@color/color2"
                        android:fontFamily="@font/lato_bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Branch -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvBranch"
                android:layout_width="0dp"
                android:layout_height="115dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:backgroundTint="@color/cabang"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/ivBranch"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/cabang"
                        android:contentDescription="@string/cabang" />

                    <TextView
                        android:id="@+id/tvBranch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cabang"
                        android:textSize="13sp"
                        android:textColor="@color/color2"
                        android:fontFamily="@font/lato_bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Print -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvPrint"
                android:layout_width="0dp"
                android:layout_height="115dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:backgroundTint="@color/cetak"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/color5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/ivPrint"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/cetak"
                        android:contentDescription="@string/cetak" />

                    <TextView
                        android:id="@+id/tvPrint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cetak"
                        android:textSize="13sp"
                        android:textColor="@color/color2"
                        android:fontFamily="@font/lato_bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>

</ScrollView>