<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/transaksi_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color1"
    tools:context=".transaksi.TransaksiActivity">

    <!-- Header Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarTransaksi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color1"
        android:layout_alignParentTop="true"
        android:padding="16dp"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/color2">

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/raleway_bold"
            android:text="Transaksi Baru"
            android:textColor="@color/color2"
            android:textSize="20sp" />
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Bottom Action Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvBottomAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/card"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/color5"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/raleway_bold"
                    android:text="Total Pembayaran"
                    android:textColor="@color/color6"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvTotalBelanja"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_bold"
                    android:text="Rp0"
                    android:textColor="@color/color4"
                    android:textSize="22sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSelesaikanTransaksi"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/button"
                android:fontFamily="@font/raleway_bold"
                android:text="SELESAI &amp; BAYAR"
                android:textAllCaps="false"
                android:textColor="@color/color3"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:elevation="2dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Main Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbarTransaksi"
        android:layout_above="@id/cvBottomAction"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <!-- Transaction Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:backgroundTint="@color/card"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/color5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Cabang Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="@font/lato_bold"
                        android:text="Cabang Toko"
                        android:textColor="@color/color2"
                        android:textSize="12sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/color4"
                        app:boxStrokeWidthFocused="2dp"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/spCabangTransaksi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lato_regular"
                            android:hint="Pilih Cabang Toko"
                            android:inputType="none"
                            android:padding="16dp"
                            android:textColor="@color/color2"
                            android:textColorHint="@color/color6"
                            android:popupBackground="@drawable/bg_dropdown"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="16dp" />

                    <!-- Produk Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="@font/lato_bold"
                        android:text="Produk"
                        android:textColor="@color/color2"
                        android:textSize="12sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/color4"
                        app:boxStrokeWidthFocused="2dp"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/spPilihProduk"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lato_regular"
                            android:hint="Pilih Produk"
                            android:inputType="none"
                            android:padding="16dp"
                            android:textColor="@color/color2"
                            android:textColorHint="@color/color6"
                            android:popupBackground="@drawable/bg_dropdown"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="16dp" />

                    <!-- Jumlah Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="@font/lato_bold"
                        android:text="Jumlah Beli"
                        android:textColor="@color/color2"
                        android:textSize="12sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/color4"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etJumlahBeli"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lato_regular"
                            android:hint="Masukkan jumlah"
                            android:inputType="number"
                            android:textColor="@color/color2"
                            android:textColorHint="@color/color6" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Add Button -->
                    <Button
                        android:id="@+id/btnTambahKeranjang"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:backgroundTint="@color/button"
                        android:fontFamily="@font/raleway_bold"
                        android:text="Tambah Ke Keranjang"
                        android:textAllCaps="false"
                        android:textColor="@color/color3"
                        android:textSize="14sp"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/raleway_bold"
                android:text="Daftar Keranjang Belanja"
                android:textColor="@color/color2"
                android:textSize="15sp" />

            <!-- Cart Recycler List Container -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@color/card"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/color5"
                app:strokeWidth="1dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvKeranjang"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingVertical="8dp"
                    tools:listitem="@layout/item_keranjang" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>