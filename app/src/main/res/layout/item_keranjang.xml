<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardKeranjang"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:backgroundTint="@color/color3"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/color5"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Product Image Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/blue_accent_light">

            <ImageView
                android:id="@+id/ivLogoKeranjang"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/produk"
                android:scaleType="centerInside"
                android:padding="8dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Product Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvNamaProdukKeranjang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nama Produk"
                android:textSize="16sp"
                android:fontFamily="@font/raleway_bold"
                android:textColor="@color/color2"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvSubTotalKeranjang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp0"
                android:textSize="14sp"
                android:fontFamily="@font/lato_bold"
                android:textColor="@color/color4"
                android:layout_marginTop="4dp"/>

            <!-- Qty Adjustment Controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <ImageButton
                    android:id="@+id/btnMinusItem"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_remove"
                    app:tint="@color/color6"
                    android:contentDescription="Kurangi Jumlah" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@color/color5"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvQtyKeranjang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jumlah Beli: 1"
                        android:textSize="11sp"
                        android:textColor="@color/color6"
                        android:fontFamily="@font/lato_bold"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnPlusItem"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_add"
                    app:tint="@color/color6"
                    android:contentDescription="Tambah Jumlah" />
            </LinearLayout>

        </LinearLayout>

        <!-- Delete Action Container -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FEE2E2"
            app:strokeWidth="0dp">

            <ImageButton
                android:id="@+id/btnHapusItem"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/hapus"
                android:scaleType="centerInside"
                android:padding="8dp"
                app:tint="@color/button2"
                android:contentDescription="Hapus Item" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>