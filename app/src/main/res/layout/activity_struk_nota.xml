<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color1"
    tools:context=".transaksi.StrukNotaActivity">

    <!-- Header Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarStruk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color1"
        android:padding="16dp"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/color2">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/raleway_bold"
            android:text="Struk Belanja"
            android:textColor="@color/color2"
            android:textSize="20sp" />
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Bottom Actions Container -->
    <LinearLayout
        android:id="@+id/llActionStruk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/color1"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/btnPrintNota"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/button"
            android:fontFamily="@font/raleway_bold"
            android:text="Cetak Struk"
            android:textAllCaps="false"
            android:textColor="@color/color3"
            android:textSize="14sp"
            app:cornerRadius="12dp"
            app:elevation="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTransaksiBaru"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:fontFamily="@font/raleway_bold"
                android:text="Selesai"
                android:textAllCaps="false"
                android:textColor="@color/color2"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/color2"
                app:strokeWidth="1.5dp" />

            <Button
                android:id="@+id/btnBagikanNota"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/raleway_bold"
                android:text="Bagikan"
                android:textAllCaps="false"
                android:textColor="@color/color2"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/color2"
                app:strokeWidth="1.5dp" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/cbAutoPrint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/lato_regular"
            android:text="Cetak otomatis setelah transaksi"
            android:textColor="@color/color6"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Receipt Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/llActionStruk"
        android:layout_below="@id/toolbarStruk"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp">

            <!-- Premium Thermal Receipt Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvReceipt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/card"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/color5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Store Brand Header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/raleway_bold"
                        android:gravity="center"
                        android:text="NexPOS"
                        android:textColor="@color/color2"
                        android:textSize="24sp"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="Jl. Raya Kelontong No. 123"
                        android:textColor="@color/color6"
                        android:textSize="13sp"
                        android:fontFamily="@font/lato_regular" />

                    <!-- Decorative Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="20dp"
                        android:background="@color/color5" />

                    <!-- Invoice ID and Date Section -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvIdStruk"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:fontFamily="@font/lato_bold"
                            android:text="ID: #TX-000000"
                            android:textColor="@color/color2"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvTanggalStruk"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/lato_regular"
                            android:text="25/05/2026 14:00"
                            android:textColor="@color/color6"
                            android:textSize="12sp" />
                    </RelativeLayout>

                    <!-- Decorative Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="20dp"
                        android:background="@color/color5" />

                    <!-- Purchased Items List (Dynamic) -->
                    <LinearLayout
                        android:id="@+id/llItemContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- Decorative Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="20dp"
                        android:background="@color/color5" />

                    <!-- Totals Block -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/lato_bold"
                            android:text="TOTAL BELANJA"
                            android:textColor="@color/color2"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvTotalNota"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lato_bold"
                            android:text="Rp0"
                            android:textColor="@color/color4"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/lato_regular"
                            android:text="Uang Tunai"
                            android:textColor="@color/color6"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvBayarNota"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lato_regular"
                            android:text="Rp0"
                            android:textColor="@color/color2"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/lato_regular"
                            android:text="Kembalian"
                            android:textColor="@color/color6"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvKembaliNota"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lato_regular"
                            android:text="Rp0"
                            android:textColor="@color/color2"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Footer Message -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="36dp"
                        android:gravity="center"
                        android:text="*** Terima Kasih Telah Berbelanja ***"
                        android:textColor="@color/color6"
                        android:textSize="11sp"
                        android:fontFamily="@font/lato_bold"
                        android:letterSpacing="0.05" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>