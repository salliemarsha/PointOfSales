<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card"
    app:strokeColor="@color/color5"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Icon Printer -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/blue_accent_light">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_printer"
                android:contentDescription="Printer Icon"
                app:tint="@color/color4"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Device Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Device Name -->
            <TextView
                android:id="@+id/tvDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bluetooth Printer"
                android:textSize="15sp"
                android:fontFamily="@font/raleway_bold"
                android:textColor="@color/color2"/>

            <!-- Device Address -->
            <TextView
                android:id="@+id/tvDeviceAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:11:22:33:44:55"
                android:textSize="12sp"
                android:fontFamily="@font/lato_regular"
                android:textColor="@color/color6"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvDeviceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pair"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:textSize="11sp"
            android:fontFamily="@font/lato_bold"
            android:textColor="@color/button"
            android:background="@drawable/bg_status_pair"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>