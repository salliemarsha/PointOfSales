<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/pembayaran_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color1"
    tools:context=".transaksi.PembayaranActivity">

    <!-- Header Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarPembayaran"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color1"
        android:layout_alignParentTop="true"
        android:padding="16dp"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/color2">

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/raleway_bold"
            android:text="Proses Pembayaran"
            android:textColor="@color/color2"
            android:textSize="20sp" />
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Bottom Action Area -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvBottomActionPembayaran"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/card"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/color5"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <Button
                android:id="@+id/btnKonfirmasiPembayaran"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/button"
                android:fontFamily="@font/raleway_bold"
                android:text="Konfirmasi Pembayaran"
                android:textAllCaps="false"
                android:textColor="@color/color3"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:elevation="2dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Main Payment Scroll Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbarPembayaran"
        android:layout_above="@id/cvBottomActionPembayaran"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <!-- Card 1: Total Bill Tagihan -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:backgroundTint="@color/blue_accent_light"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/color4"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/raleway_bold"
                        android:text="TOTAL TAGIHAN"
                        android:textColor="@color/color4"
                        android:textSize="12sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvTotalTagihan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/raleway_bold"
                        android:text="Rp0"
                        android:textColor="@color/color2"
                        android:textSize="32sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Cash Received Inputs & Cash Quick Buttons -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="8dp"
                android:backgroundTint="@color/card"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/color5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/lato_bold"
                        android:text="Nominal Uang Diterima"
                        android:textColor="@color/color2"
                        android:textSize="12sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/color4"
                        app:boxStrokeWidthFocused="2dp"
                        app:hintEnabled="false"
                        app:prefixText="Rp "
                        app:prefixTextColor="@color/color2">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etUangBayar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lato_regular"
                            android:hint="Masukkan jumlah uang"
                            android:inputType="number"
                            android:textColor="@color/color2"
                            android:textColorHint="@color/color6" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Quick Cash Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:columnCount="3"
                        android:rowCount="2">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUangPas"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_columnWeight="1"
                            android:fontFamily="@font/lato_bold"
                            android:text="Uang Pas"
                            android:textColor="@color/button"
                            android:textSize="11sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/button"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNominal10k"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_columnWeight="1"
                            android:fontFamily="@font/lato_bold"
                            android:text="10.000"
                            android:textColor="@color/color2"
                            android:textSize="11sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/color5"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNominal20k"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_columnWeight="1"
                            android:fontFamily="@font/lato_bold"
                            android:text="20.000"
                            android:textColor="@color/color2"
                            android:textSize="11sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/color5"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNominal50k"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_columnWeight="1"
                            android:fontFamily="@font/lato_bold"
                            android:text="50.000"
                            android:textColor="@color/color2"
                            android:textSize="11sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/color5"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNominal100k"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_columnWeight="1"
                            android:fontFamily="@font/lato_bold"
                            android:text="100.000"
                            android:textColor="@color/color2"
                            android:textSize="11sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/color5"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnResetNominal"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_columnWeight="1"
                            android:fontFamily="@font/lato_bold"
                            android:text="Reset"
                            android:textColor="@color/button2"
                            android:textSize="11sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/button2"
                            app:strokeWidth="1dp" />
                    </GridLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 3: Uang Kembalian (Change Due) - Highlighted in soft green -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="8dp"
                android:backgroundTint="@color/layanan"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/color5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/raleway_bold"
                        android:text="UANG KEMBALIAN"
                        android:textColor="@color/color2"
                        android:textSize="12sp"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvUangKembalian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/raleway_bold"
                        android:text="Rp0"
                        android:textColor="@color/color2"
                        android:textSize="20sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>